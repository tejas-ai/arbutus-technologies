{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/client-dashboard",
      "regex": "^/client\\-dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/client\\-dashboard(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/line-card",
      "regex": "^/line\\-card(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/line\\-card(?:/)?$"
    },
    {
      "page": "/products/electronic-integrated-circuits",
      "regex": "^/products/electronic\\-integrated\\-circuits(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/electronic\\-integrated\\-circuits(?:/)?$"
    },
    {
      "page": "/products/memory",
      "regex": "^/products/memory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/memory(?:/)?$"
    },
    {
      "page": "/products/power-devices",
      "regex": "^/products/power\\-devices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/power\\-devices(?:/)?$"
    },
    {
      "page": "/products/protection-devices",
      "regex": "^/products/protection\\-devices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/protection\\-devices(?:/)?$"
    },
    {
      "page": "/products/sensors",
      "regex": "^/products/sensors(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/sensors(?:/)?$"
    },
    {
      "page": "/products/timing-devices",
      "regex": "^/products/timing\\-devices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/timing\\-devices(?:/)?$"
    },
    {
      "page": "/services/rd-capabilities",
      "regex": "^/services/rd\\-capabilities(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services/rd\\-capabilities(?:/)?$"
    },
    {
      "page": "/success",
      "regex": "^/success(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/success(?:/)?$"
    },
    {
      "page": "/tools",
      "regex": "^/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tools(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
